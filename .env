# Google Gemini (FREE - 1500 requests/day)
GOOGLE_API_KEY=AIzaSyCk25JVUrlyE6bdgxDV46o_usH38tHn14A
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash-exp  # FREE tier model

# Alternative: Ollama (100% offline, FREE)
USE_LOCAL_FALLBACK=true
LOCAL_MODEL=llama3.1:8b

# LangSmith (FREE tier - 5000 traces/month)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_free_langsmith_key_here
LANGCHAIN_PROJECT=aegis-hackathon

# Redis (FREE - local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Routing (FREE - OpenStreetMap)
OPENROUTE_API_KEY=  # Leave empty - using mock routing
USE_MOCK_ROUTING=true

# System Thresholds
VALIDATION_CONFIDENCE_THRESHOLD=0.4
DEDUP_SIMILARITY_THRESHOLD=0.85
MAX_DISPATCH_LATENCY_SECONDS=3

# Deployment
ENVIRONMENT=development
LOG_LEVEL=INFO